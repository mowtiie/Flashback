<?xml version="1.0" encoding="utf-8"?>
<!--
  Light scheme, generated from a teal seed rather than the stock Material
  purple. Android 12+ replaces these at runtime via dynamic colour; they are
  the fallback for everything older.

  The night variant lives in values-night/colors.xml under the same names, so
  themes.xml needs no dark duplicate.
-->
<resources>
    <color name="md_primary">#006A60</color>
    <color name="md_on_primary">#FFFFFF</color>
    <color name="md_primary_container">#74F8E8</color>
    <color name="md_on_primary_container">#00201C</color>

    <color name="md_secondary">#4A635F</color>
    <color name="md_on_secondary">#FFFFFF</color>
    <color name="md_secondary_container">#CCE8E2</color>
    <color name="md_on_secondary_container">#05201C</color>

    <color name="md_tertiary">#825500</color>
    <color name="md_on_tertiary">#FFFFFF</color>
    <color name="md_tertiary_container">#FFDDB3</color>
    <color name="md_on_tertiary_container">#291800</color>

    <color name="md_error">#BA1A1A</color>
    <color name="md_on_error">#FFFFFF</color>
    <color name="md_error_container">#FFDAD6</color>
    <color name="md_on_error_container">#410002</color>

    <color name="md_background">#FAFDFB</color>
    <color name="md_on_background">#191C1B</color>
    <color name="md_surface">#FAFDFB</color>
    <color name="md_on_surface">#191C1B</color>
    <color name="md_surface_variant">#DAE5E1</color>
    <color name="md_on_surface_variant">#3F4947</color>
    <color name="md_surface_container">#EFF2F0</color>
    <color name="md_outline">#6F7976</color>
    <color name="md_outline_variant">#BEC9C5</color>

    <!--
      Study counts. These are semantic, not decorative: the same hue always
      means the same queue, on the deck card and later on the study screen.
    -->
    <color name="count_new">#1B5FC4</color>
    <color name="count_learning">#A2521A</color>
    <color name="count_due">#1E7B4F</color>
</resources>
