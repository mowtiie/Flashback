<?xml version="1.0" encoding="utf-8"?>
<!--
  Shared empty state. Every screen that can be empty uses this, so the shape of
  "nothing here yet" is identical everywhere and always ends in an action.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="@dimen/spacing_xl"
    android:paddingEnd="@dimen/spacing_xl"
    android:visibility="gone">

    <ImageView
        android:id="@+id/emptyIcon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginBottom="@dimen/spacing_md"
        android:contentDescription="@null"
        android:src="@drawable/ic_school"
        app:tint="?attr/colorOnSurfaceVariant" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/emptyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        tools:text="No decks yet" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/emptyBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:gravity="center"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/emptyAction"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg" />

</LinearLayout>
